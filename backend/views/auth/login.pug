//- views/auth/login.pug

extends ../layout

block content
  .auth-page
    .auth-card
      .auth-card__header
        a.auth-card__back(href="/") ← Back
        h1.auth-card__title Sign In
        p.auth-card__sub Access your SmartCampus account

      //- Server-side errors
      if errors && errors.length > 0
        .form-errors
          each err in errors
            p.form-error-item ✕ #{err}

      form#loginForm.auth-form(action="/auth/login", method="POST", novalidate)

        .form-group
          label.form-label(for="email") Email Address
          input.form-input#email(
            type="email",
            name="email",
            id="email",
            placeholder="you@example.com",
            value= formData.email || '',
            autocomplete="email"
          )
          span.field-error#emailError

        .form-group
          label.form-label(for="password") Password
          .input-wrapper
            input.form-input#password(
              type="password",
              name="password",
              id="password",
              placeholder="Your password",
              autocomplete="current-password"
            )
            button.input-toggle(type="button", data-target="password", aria-label="Toggle password") 👁
          span.field-error#passwordError

        button.btn.btn--primary.btn--full(type="submit") Sign In

      p.auth-card__switch
        | Don't have an account?
        a(href="/auth/register")  Register here

block scripts
  script(src="/js/validate-login.js")
