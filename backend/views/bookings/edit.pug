//- views/bookings/edit.pug

extends ../layout

block content
  .container
    a.back-link(href="/dashboard") ← Back to Dashboard

    .form-page
      .form-page__header
        h1.form-page__title Edit Booking
        p.form-page__sub
          | Editing booking for
          strong  #{booking.resource ? booking.resource.name : 'Unknown Resource'}

      if errors && errors.length > 0
        .form-errors
          each err in errors
            p.form-error-item ✕ #{err}

      form#bookingForm.form-card(action="/bookings/" + booking._id + "/edit", method="POST", novalidate)

        //- Resource is fixed on edit — just show it as read-only
        .form-group
          label.form-label Resource
          .form-input.form-input--readonly
            = booking.resource ? booking.resource.name + ' (' + booking.resource.category + ')' : 'Unknown'
          input(type="hidden", name="resourceId", value= booking.resource ? booking.resource._id : '')

        .form-row
          .form-group
            label.form-label(for="date") Date *
            input.form-input#date(
              type="date",
              name="date",
              
              value= formData.date || booking.date.toISOString().split('T')[0],
              min= new Date().toISOString().split('T')[0]
            )
            span.field-error#dateError

        .form-row
          .form-group
            label.form-label(for="startTime") Start Time *
            select.form-input#startTime(name="startTime")
              - var hours = ['08:00','08:30','09:00','09:30','10:00','10:30','11:00','11:30','12:00','12:30','13:00','13:30','14:00','14:30','15:00','15:30','16:00','16:30','17:00','17:30','18:00','18:30','19:00','19:30','20:00']
              each slot in hours
                - var selected = (formData.startTime || booking.startTime) === slot
                option(value=slot, selected=selected) #{slot}
            span.field-error#startTimeError

          .form-group
            label.form-label(for="endTime") End Time *
            select.form-input#endTime(name="endTime")
              each slot in hours
                - var selected = (formData.endTime || booking.endTime) === slot
                option(value=slot, selected=selected) #{slot}
            span.field-error#endTimeError

        #bookedSlotsDisplay.booked-slots(style="display:none")
          h4.booked-slots__title Already Booked (Other Bookings)
          ul.booked-slots__list#bookedSlotsList

        .form-group
          label.form-label(for="purpose") Purpose (optional)
          textarea.form-input.form-input--textarea#purpose(
            name="purpose",
            rows="3"
          ) #{formData.purpose || booking.purpose || ''}

        .form-actions
          button.btn.btn--primary(type="submit") Save Changes
          a.btn.btn--outline(href="/dashboard") Cancel

        //- Pass resource ID and current booking ID to client JS
        input(type="hidden", id="currentBookingId", value= booking._id)

block scripts
  script(src="/js/booking-form.js")
